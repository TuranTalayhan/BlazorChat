@using BlazorChat.Server.Data
@using BlazorChat.Server.Data.Entities
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@inject AppDbContext DbContext
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="mr-3 mb-n1"/>
            Add Friend
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-4" Style="color: #666;">
            Start typing a username to see suggestions.
        </MudText>
        
        @* Autocomplete replaces the standard TextField *@
        <MudAutocomplete T="string" 
                         Label="Username" 
                         @bind-Value="_username" 
                         SearchFunc="@SearchUsers"
                         Variant="Variant.Outlined" 
                         Placeholder="Search for users..." 
                         Adornment="Adornment.Start" 
                         AdornmentIcon="@Icons.Material.Filled.Search"
                         Margin="Margin.Dense"
                         ResetValueOnEmptyText="true"
                         CoerceText="true"
                         OnAdornmentClick="Submit" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Success" 
                   Variant="Variant.Filled" 
                   OnClick="Submit" 
                   Class="btn-pill px-6"
                   Disabled="@(string.IsNullOrWhiteSpace(_username))">
            Send Request
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    private string? _username;
    private int _currentUserId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        int.TryParse(authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out _currentUserId);
    }

    // This function handles the suggestions logic
    private async Task<IEnumerable<string>> SearchUsers(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value) || value.Length < 2)
            return new List<string>();

        // Find users starting with the input, excluding self
        return await DbContext.Users
            .Where(u => u.Id != _currentUserId && u.Username.ToLower().Contains(value.ToLower()))
            .Take(5) // Limit suggestions for performance
            .Select(u => u.Username)
            .ToListAsync(token);
    }

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_username)) return;

        var targetUser = await DbContext.Users.FirstOrDefaultAsync(u => u.Username == _username);
        
        if (targetUser == null)
        {
            Snackbar.Add("User not found.", Severity.Error);
            return;
        }

        // Check if already friends or pending
        var alreadyLinked = await DbContext.Friendships.AnyAsync(f => 
            (f.RequesterId == _currentUserId && f.ReceiverId == targetUser.Id) || 
            (f.RequesterId == targetUser.Id && f.ReceiverId == _currentUserId));

        if (alreadyLinked)
        {
            Snackbar.Add("Relationship already exists or is pending.", Severity.Info);
            return;
        }

        var request = new Friendship { RequesterId = _currentUserId, ReceiverId = targetUser.Id, Status = FriendshipStatus.Pending };
        DbContext.Friendships.Add(request);
        await DbContext.SaveChangesAsync();

        Snackbar.Add("Friend request sent!", Severity.Success);
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}