@inherits LayoutComponentBase

<div class="app-layout">
    
    @* We use @bind- to automatically sync the state between this layout and the sidebar *@
    <PrimarySidebar @bind-IsDirectMessageMode="_isDirectMessageMode" />
    
    @if (!_isDirectMessageMode)
    {
        <aside class="secondary-nav">
        </aside>
    }

    <main class="chat-area">
        @Body
    </main>
</div>

@code {
    private bool _isDirectMessageMode = true;
}