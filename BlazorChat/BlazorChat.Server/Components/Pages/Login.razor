@page "/"

@using System.Security.Claims
@using BlazorChat.Server.Data
@using BlazorChat.Server.Data.Entities
@using BlazorChat.Shared.DTO
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@layout AuthLayout

@inject AppDbContext DbContext
@inject NavigationManager NavManager

<EditForm Model="@LoginModel" OnValidSubmit="LoginUser" FormName="LoginForm">
    <DataAnnotationsValidator />

    <MudText Align="Align.Center" Class="font-weight-bold mb-6" Style="color: #333333;font-size: 2.5rem;">
        Welcome Back!
    </MudText>
    
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4">@_errorMessage</MudAlert>
    }
    
    <MudTextField @bind-Value="LoginModel.Email" 
                  For="@(() => LoginModel.Email)"
                  name="LoginModel.Email"
                  Placeholder="Email or Username"
                  Variant="Variant.Outlined" 
                  Margin="Margin.Dense" 
                  Class="mb-4" />

    <MudTextField @bind-Value="LoginModel.Password" 
                  For="@(() => LoginModel.Password)"
                  name="LoginModel.Password"
                  Placeholder="Password" 
                  InputType="InputType.Password" 
                  Variant="Variant.Outlined" 
                  Margin="Margin.Dense" 
                  Class="mb-6" />
    
    <MudButton ButtonType="ButtonType.Submit" 
               Variant="Variant.Filled" 
               Color="Color.Info" 
               FullWidth="true" 
               Class="btn-pill py-2 mb-4" 
               DisableElevation="true">
        Log In
    </MudButton>

    <div class="d-flex justify-center mb-4">
        <MudLink Href="#" Typo="Typo.body2" Style="color: #9e9e9e;">Forgot your password?</MudLink>
    </div>

    <div class="d-flex align-center justify-center mt-2">
        <MudText Typo="Typo.body2" Style="color: #9e9e9e;" Class="mr-2">Need an account?</MudText>
        <MudButton Href="/register" Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small" Style="text-transform: none; border-radius: 6px; padding: 2px 10px;">
            Sign Up
        </MudButton>
    </div>

</EditForm>

@code
{
    [SupplyParameterFromForm]
    public LoginDto LoginModel { get; set; }
    
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private string _errorMessage = "";
    
    protected override void OnInitialized()
    {
        LoginModel ??= new();
        
        if (HttpContext?.User.Identity?.IsAuthenticated == true)
        {
            NavManager.NavigateTo("/chat", forceLoad: true);
        }
    }
    
    private async Task LoginUser()
    {
        _errorMessage = "";
        
        // 1. FIND THE USER IN THE DATABASE
        // We check if the input matches the Email OR the Username
        var identifier = LoginModel.Email.ToLower().Trim();

        var user = await DbContext.Users.FirstOrDefaultAsync(u => 
            u.Email.ToLower() == identifier || 
            u.Username.ToLower() == identifier);

        if (user == null)
        {
            // We use a generic message so hackers don't know which part was wrong
            _errorMessage = "Invalid credentials."; 
            return;
        }

        // 2. VERIFY THE PASSWORD (stays the same)
        var passwordHasher = new PasswordHasher<User>();
        var verificationResult = passwordHasher.VerifyHashedPassword(user, user.PasswordHash, LoginModel.Password);

        if (verificationResult == PasswordVerificationResult.Failed)
        {
            _errorMessage = "Invalid credentials.";
            return;
        }

        // 3. CREATE THE SECURITY TICKET (stays the same)
        // Even if they logged in with email, we grab their actual Username from the DB for the claim
        var claims = new List<Claim>
        {
            new(ClaimTypes.Name, user.Username),
            new(ClaimTypes.Email, user.Email),
            new(ClaimTypes.NameIdentifier, user.Id.ToString())
        };

        var identity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);
        var principal = new ClaimsPrincipal(identity);

        // 4. ISSUE THE HTTP-ONLY COOKIE
        if (HttpContext != null)
        {
            await HttpContext.SignInAsync(CookieAuthenticationDefaults.AuthenticationScheme, principal);
            
            // 5. REDIRECT TO THE CHAT APP
            NavManager.NavigateTo("/chat");
        }
        else
        {
            _errorMessage = "An internal error occurred. Please try again.";
        }
    }
}