@using BlazorChat.Client.Features.Servers.ViewModels
@using BlazorChat.Shared.Enums
@inject ServerMembersViewModel ViewModel
@implements IDisposable

<aside class="members-sidebar">
    <div class="members-sidebar-header px-4 py-3">
        <MudText Typo="Typo.subtitle2" Class="fw-bold text-uppercase" Style="color: #6a6f74; font-size: 0.75rem; letter-spacing: 0.5px;">
            Server Members — @ViewModel.Members.Count
        </MudText>
    </div>

    <div class="members-list px-2">
        @if (ViewModel.IsLoading)
        {
            <div class="d-flex justify-center pa-4">
                <MudProgressCircular Color="Color.Secondary" Indeterminate="true" Size="Size.Small" />
            </div>
        }
        else if (!ViewModel.Members.Any())
        {
            <div class="pa-4 text-center" style="color: #8a8f95; font-size: 0.85rem;">No members found</div>
        }
        else
        {
            @foreach (var member in ViewModel.Members)
            {
                <div class="member-item d-flex align-center justify-space-between px-2 py-1" @key="member.Id">
                    <div class="d-flex align-center">
                        <div class="avatar">
                            @if (!string.IsNullOrEmpty(member.AvatarUrl))
                            {
                                <img src="@member.AvatarUrl" alt="@member.Username" class="avatar-image" />
                            }
                            else
                            {
                                <span>@(member.Username.ToUpper()[0])</span>
                            }
                            <div class="status @ViewModel.GetStatusClass(member.Status)"></div>
                        </div>

                        <div class="member-details ml-2">
                            <div class="d-flex align-center">
                                <span class="member-name @ViewModel.GetRoleCssClass(member.Role)">
                                    @member.Username
                                </span>

                                @switch (member.Role)
                                {
                                    case ServerRole.Owner:
                                        <span class="role-badge owner-badge ml-1">Owner</span>
                                        break;
                                    case ServerRole.Admin:
                                        <span class="role-badge admin-badge ml-1">Admin</span>
                                        break;
                                }
                            </div>
                        </div>
                    </div>

                    @if (ViewModel.IsCurrentUserOwner && member.Role != ServerRole.Owner)
                    {
                        <div class="member-actions-context">
                            <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                @if (member.Role == ServerRole.Admin)
                                {
                                    <MudMenuItem Icon="@Icons.Material.Filled.ArrowDownward" 
                                                 IconColor="Color.Warning" 
                                                 OnClick="@(() => ViewModel.ChangeUserRoleAsync(member.Id, ServerRole.Member))">
                                        Demote to Member
                                    </MudMenuItem>
                                }
                                else
                                {
                                    <MudMenuItem Icon="@Icons.Material.Filled.ArrowUpward" 
                                                 IconColor="Color.Success" 
                                                 OnClick="@(() => ViewModel.ChangeUserRoleAsync(member.Id, ServerRole.Admin))">
                                        Promote to Admin
                                    </MudMenuItem>
                                }
                            </MudMenu>
                        </div>
                    }
                </div>
            }
        }
    </div>
</aside>

@code {
    protected override async Task OnInitializedAsync()
    {
        ViewModel.StateChanged += OnViewModelStateChanged;
        await ViewModel.InitializeAsync();
    }

    private void OnViewModelStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        ViewModel.StateChanged -= OnViewModelStateChanged;
        ViewModel.Dispose();
    }
}