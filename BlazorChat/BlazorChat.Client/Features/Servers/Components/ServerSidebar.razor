@inject ServerChannelsViewModel ViewModel
@using BlazorChat.Client.Features.Servers.Dialogs.CreateCategory
@using BlazorChat.Client.Features.Servers.ViewModels
@using CreateChannelDialog = BlazorChat.Client.Features.Servers.Dialogs.CreateChannel.CreateChannelDialog
@inject IDialogService DialogService
@implements IDisposable

<div class="channel-sidebar-header d-flex align-center justify-space-between px-4 py-2">
    <MudText Typo="Typo.subtitle1" Class="fw-bold">@Server.Name</MudText>
    <MudMenu Icon="@Icons.Material.Filled.KeyboardArrowDown" AnchorOrigin="Origin.BottomRight">
        <MudMenuItem OnClick="OpenCreateCategoryDialog" Icon="@Icons.Material.Filled.CreateNewFolder">Create Category</MudMenuItem>
        <MudMenuItem OnClick="@(() => OpenCreateChannelDialog())" Icon="@Icons.Material.Filled.AddCircle">Create Channel</MudMenuItem>
    </MudMenu>
</div>

<div class="channel-list">
    @if (ViewModel.IsLoading)
    {
        <div class="d-flex justify-center pa-4">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
        </div>
    }
    else if (!ViewModel.Channels.Any())
    {
        <div class="channel-empty pa-4 text-center">No channels yet</div>
    }
    else
    {
        @foreach (var ch in ViewModel.RootChannels)
        {
            <div class="channel-item @ViewModel.GetChannelClass(ch.Id)" @onclick="() => ViewModel.Navigate(ch.Id)">
                <MudIcon Icon="@Icons.Material.Filled.Tag" Size="Size.Small" Class="mr-2" />
                <span class="channel-name">@ch.Name</span>
            </div>
        }
        
        @foreach (var group in ViewModel.CategorizedGroups)
        {
            <div class="category-header d-flex align-center mt-2 px-2">
                <div class="flex-grow-1 d-flex align-center cursor-pointer" @onclick="() => ViewModel.ToggleCategory(group.Key.Id)">
                    <MudIcon Icon="@(ViewModel.IsExpanded(group.Key.Id) ? Icons.Material.Filled.KeyboardArrowDown : Icons.Material.Filled.KeyboardArrowRight)" 
                             Size="Size.Small" Class="mr-1" />
                    <MudText Typo="Typo.overline" Style="letter-spacing: 1px;">@group.Key.Name.ToUpper()</MudText>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" 
                               OnClick="@(() => OpenCreateChannelDialog(group.Key.Id))" Class="pa-1" />
            </div>

            @if (ViewModel.IsExpanded(group.Key.Id))
            {
                @foreach (var ch in group)
                {
                    <div class="channel-item @ViewModel.GetChannelClass(ch.Id)" @onclick="() => ViewModel.Navigate(ch.Id)">
                        <MudIcon Icon="@Icons.Material.Filled.Tag" Size="Size.Small" Class="mr-2" />
                        <span class="channel-name">@ch.Name</span>
                    </div>
                }
            }
        }
    }
</div>

@code {
    [Parameter, EditorRequired] public ServerDto Server { get; set; } = null!;
    
    protected override async Task OnParametersSetAsync() 
        => await ViewModel.InitializeAsync(Server.Id);
    
    protected override void OnInitialized()
    {
        ViewModel.StateChanged += OnViewModelStateChanged;
    }

    private async Task OpenCreateChannelDialog(int? categoryId = null)
    {
        var parameters = new DialogParameters<CreateChannelDialog> 
        { 
            { x => x.ServerId, Server.Id },
            { x => x.PreSelectedCategoryId, categoryId }
        };
        
        var dialog = await DialogService.ShowAsync<CreateChannelDialog>("New Channel", parameters);
    
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: ChannelDto newChannel })
        {
            ViewModel.AddChannel(newChannel);
        }
    }

    private async Task OpenCreateCategoryDialog()
    {
        var parameters = new DialogParameters<CreateCategoryDialog> 
        { 
            { x => x.ServerId, Server.Id } 
        };
    
        var dialog = await DialogService.ShowAsync<CreateCategoryDialog>("New Category", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: CategoryDto newCategory })
        {
            ViewModel.AddCategory(newCategory);
        }
    }
    private void OnViewModelStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ViewModel.StateChanged -= OnViewModelStateChanged;
        ViewModel.Dispose();
    }
}