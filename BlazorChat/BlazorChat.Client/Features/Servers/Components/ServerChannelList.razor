@inject SidebarViewModel ViewModel
@using BlazorChat.Client.Features.Servers.ViewModels
@implements IDisposable

<div class="channel-sidebar-header d-flex align-center justify-space-between px-4 py-2">
    <MudText Typo="Typo.subtitle1" Class="fw-bold">@Server.Name</MudText>
    <MudMenu Icon="@Icons.Material.Filled.KeyboardArrowDown">
        <MudMenuItem OnClick="OpenCreateCategory" Icon="@Icons.Material.Filled.CreateNewFolder">Category</MudMenuItem>
        <MudMenuItem OnClick="() => ViewModel.OpenCreateChannelDialog(Server.Id)" Icon="@Icons.Material.Filled.AddCircle">Channel</MudMenuItem>
    </MudMenu>
</div>

<div class="channel-list">
    @if (ViewModel.IsLoading)
    {
        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
    }
    else 
    {
        @foreach (var ch in ViewModel.RootChannels) 
        {
            <ChannelItem Channel="ch" IsActive="ViewModel.ActiveChannelId == ch.Id" OnClick="() => ViewModel.NavTo(ch.Id)" />
        }

        @foreach (var group in ViewModel.CategorizedGroups) 
        {
            <div class="category-header d-flex align-center mt-2 px-2">
                <div @onclick="() => ViewModel.ToggleCategory(group.Key)" class="flex-grow-1 cursor-pointer">
                    <MudIcon Icon="@(ViewModel.CollapsedCategories.Contains(group.Key) ? Icons.Material.Filled.KeyboardArrowRight : Icons.Material.Filled.KeyboardArrowDown)" />
                    <MudText Typo="Typo.overline">@group.Key.ToUpper()</MudText>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Add" OnClick="() => ViewModel.OpenCreateChannelDialog(Server.Id, group.Key)" />
            </div>

            @if (!ViewModel.CollapsedCategories.Contains(group.Key)) {
                @foreach (var ch in group) {
                    <ChannelItem Channel="ch" IsActive="ViewModel.ActiveChannelId == ch.Id" OnClick="() => ViewModel.NavTo(ch.Id)" />
                }
            }
        }
    }
</div>

@code {
    [Parameter] public ServerDto Server { get; set; } = null!;

    protected override void OnInitialized() => ViewModel.Initialize();
    protected override async Task OnParametersSetAsync() => await ViewModel.LoadChannelsAsync(Server.Id);
    
    private async Task OpenCreateCategory() { /* Similar logic to OpenCreateChannel */ }

    public void Dispose() => ViewModel.Dispose();
}