@implements IDisposable
@inject CreateServerViewModel ViewModel
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.AddBusiness" Class="mr-3 mb-n1" />
            Create Your Server
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-4" Style="color: #666;">
            Give your new server a personality with a name and an icon. You can always change this later.
        </MudText>
        <div class="d-flex flex-column align-center mb-6">
            <MudBadge Color="Color.Primary" Overlap="true" Bordered="true" Icon="@Icons.Material.Filled.PhotoCamera" Placement="Placement.BottomRight">
                <MudAvatar>@ViewModel.AvatarInitial</MudAvatar>
            </MudBadge>
            <MudLink Typo="Typo.caption" Class="mt-2">Upload Icon</MudLink>
        </div>
        <MudTextField @bind-Value="ViewModel.ServerName"
                      Label="Server Name"
                      Variant="Variant.Outlined"
                      Immediate="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Submit"
                   Disabled="@(!ViewModel.CanSubmit)">
            @if (ViewModel.IsSubmitting) { <MudProgressCircular Size="Size.Small" Indeterminate="true" /> }
            Create Server
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    protected override void OnInitialized() => ViewModel.OnChanged += StateHasChanged;

    private async Task Submit()
    {
        var result = await ViewModel.CreateServerAsync();

        if (result != null)
        {
            MudDialog.Close(DialogResult.Ok(result));
        }
        else if (!string.IsNullOrEmpty(ViewModel.ErrorMessage))
        {
            Snackbar.Add(ViewModel.ErrorMessage, Severity.Error);
        }
    }

    private void Cancel() => MudDialog.Cancel();

    public void Dispose() => ViewModel.OnChanged -= StateHasChanged;
}
