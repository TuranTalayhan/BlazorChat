<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Create Text Channel</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="4">
            <MudTextField @bind-Value="_channelName" 
                          Label="Channel Name" 
                          Variant="Variant.Outlined" 
                          Placeholder="new-channel"
                          Adornment="Adornment.Start" 
                          AdornmentIcon="@Icons.Material.Filled.Tag" 
                          Immediate="true"
                          AutoFocus="true" />
            
            <MudTextField @bind-Value="_category" 
                          Label="Category (Optional)" 
                          Variant="Variant.Outlined" 
                          HelperText="Leave empty for uncategorized" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" 
                   Variant="Variant.Filled" 
                   OnClick="Submit" 
                   Disabled="@(string.IsNullOrWhiteSpace(_channelName))">Create Channel</MudButton>
    </DialogActions>
</MudDialog>