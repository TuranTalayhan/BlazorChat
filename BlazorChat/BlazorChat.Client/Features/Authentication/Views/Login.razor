@page "/"
@layout AuthLayout
@using BlazorChat.Client.Features.Authentication.Layouts
@using BlazorChat.Client.Features.Authentication.ViewModels
@inject LoginViewModel ViewModel
@inject NavigationManager Nav
@implements IDisposable

<EditForm Model="@ViewModel.Model" OnValidSubmit="ViewModel.LoginUserAsync">
    <DataAnnotationsValidator />

    <MudText Align="Align.Center" Class="font-weight-bold mb-6" Style="color: #333333;font-size: 2.5rem;">
        Welcome Back!
    </MudText>

    @if (!string.IsNullOrEmpty(ViewModel.ErrorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4">@ViewModel.ErrorMessage</MudAlert>
    }

    <MudTextField @bind-Value="ViewModel.Model.Email"
                  For="@(() => ViewModel.Model.Email)"
                  Disabled="ViewModel.IsLoading"
                  Placeholder="Email or Username"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Class="mb-4" />

    <MudTextField @bind-Value="ViewModel.Model.Password"
                  For="@(() => ViewModel.Model.Password)"
                  Disabled="ViewModel.IsLoading"
                  Placeholder="Password"
                  InputType="InputType.Password"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Class="mb-6" />

    <MudButton ButtonType="ButtonType.Submit"
               Variant="Variant.Filled"
               Color="Color.Info"
               FullWidth="true"
               Class="btn-pill py-2 mb-4"
               DisableElevation="true"
               Disabled="ViewModel.IsLoading">
        @(ViewModel.IsLoading ? "Logging in..." : "Log In")
    </MudButton>

    <div class="d-flex justify-center mb-4">
        <MudLink Href="#" Typo="Typo.body2" Style="color: #9e9e9e;">Forgot your password?</MudLink>
    </div>

    <div class="d-flex align-center justify-center mt-2">
        <MudText Typo="Typo.body2" Style="color: #9e9e9e;" Class="mr-2">Need an account?</MudText>
        <MudButton Href="/register" Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small" Style="text-transform: none; border-radius: 6px; padding: 2px 10px;">
            Sign Up
        </MudButton>
    </div>
</EditForm>

@code {
    protected override async Task OnInitializedAsync()
    {
        ViewModel.OnLoginSuccess += HandleLoginSuccess;
        
        await ViewModel.CheckUserStatus();
    }

    private void HandleLoginSuccess()
    {
        Nav.NavigateTo("/chat");
    }

    public void Dispose()
    {
        ViewModel.OnLoginSuccess -= HandleLoginSuccess;
    }
}
