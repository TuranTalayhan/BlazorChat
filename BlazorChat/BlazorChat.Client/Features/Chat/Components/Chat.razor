@page "/chat"
@page "/chat/{ChannelId:int}"
@attribute [Authorize]
@inject ChatViewModel ViewModel
@using BlazorChat.Client.Features.Chat.ViewModels
@using BlazorChat.Shared.Constants
@inject NavigationState NavState
@implements IDisposable

<div class="chat-container">
    @if (!string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
    {
        <div class="no-channel-placeholder pa-6 d-flex flex-column align-center justify-center" style="height: 100%;">
            <MudIcon Icon="@Icons.Material.Filled.GppBad" Style="font-size:4rem; color:#f23f43;" Class="mb-2" />
            <MudText Typo="Typo.h6" Style="color: #111111; font-weight: 600;" Class="mb-1">
                Access Denied
            </MudText>
            <MudText Typo="Typo.body2" Style="color: #555555; max-width: 300px;" Align="Align.Center">
                @ViewModel.ErrorMessage
            </MudText>
        </div>
    }
    else if (ViewModel.LoadedChannelId == 0)
    {
        <div class="no-channel-placeholder">
            <MudIcon Icon="@Icons.Material.Filled.Forum" Style="font-size:3rem;color:#4f545c;" />
            <p>Select a channel to start chatting</p>
        </div>
    }
    else
    {
        <div class="message-scroll-container">
            @if (ViewModel.HasMoreMessages)
            {
                <div class="load-more-sentinel" style="text-align: center; padding: 12px; color: #b9bbbe;">
                    @if (ViewModel.IsLoadingMore)
                    {
                        <MudProgressCircular Color="Color.Secondary" Indeterminate="true" Size="Size.Small" />
                        <span style="margin-left: 8px; font-size: 0.85rem;">Loading past history...</span>
                    }
                    else
                    {
                        <button type="button" class="load-more-btn" @onclick="ViewModel.LoadNextChunkAsync" 
                                style="background: none; border: none; color: #00b0f4; cursor: pointer; font-size: 0.85rem;">
                            Load older messages
                        </button>
                    }
                </div>
            }
            
            <Virtualize Items="ViewModel.Messages" Context="msg" OverscanCount="10" ItemSize="70">
                <ItemTemplate>
                    <div @key="msg.Id" class="message-item-wrapper">
                        <MessageItem Message="msg" IsMe="msg.AuthorId == ViewModel.CurrentUserId" />
                    </div>
                </ItemTemplate>
            </Virtualize>
        </div>

        <div class="chat-input-footer" style="display:flex; justify-content:flex-end; font-size: 0.8rem; margin-top: 4px;">
            <span style="color: @(IsOverLimit ? "red" : "gray")">
                @CurrentMessageLength / @ChatConstants.MaxMessageLength
            </span>
            @if (IsOverLimit)
            {
                <span style="color: red; margin-left: 8px;">Message is too long!</span>
            }
        </div>

        <div class="chat-input-wrapper">
            <input @ref="_inputRef" 
                   class="chat-input" 
                   @bind="ViewModel.CurrentMessage" 
                   @bind:event="oninput"
                   @onkeydown="HandleKey" 
                   disabled="@ViewModel.IsSending" />
            
            <MudIconButton Icon="@Icons.Material.Filled.Send" 
                           OnClick="ViewModel.SendAsync" 
                           Disabled="@IsSendDisabled" />
        </div>
    }
</div>

@code {
    [Parameter] public int ChannelId { get; set; }
    private ElementReference _inputRef;

    private int CurrentMessageLength => ViewModel.CurrentMessage?.Length ?? 0;
    private bool IsOverLimit => CurrentMessageLength > ChatConstants.MaxMessageLength;
    
    private bool IsSendDisabled => string.IsNullOrWhiteSpace(ViewModel.CurrentMessage) 
                                || ViewModel.IsSending 
                                || IsOverLimit;

    protected override async Task OnInitializedAsync()
    {
        ViewModel.OnChanged += OnViewModelChanged;        
        await ViewModel.InitializeAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (ChannelId > 0)
        {
            NavState.SetActiveChannel(ChannelId);
        }

        await ViewModel.LoadChannelAsync(ChannelId);
    }

    private async Task HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !IsSendDisabled)
        {
            await ViewModel.SendAsync();
            await _inputRef.FocusAsync();
        }
    }

    private void OnViewModelChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => ViewModel.OnChanged -= OnViewModelChanged;
}