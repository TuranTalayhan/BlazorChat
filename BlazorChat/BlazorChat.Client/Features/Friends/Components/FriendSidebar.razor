@inject FriendsSidebarViewModel ViewModel
@using BlazorChat.Client.Features.Friends.ViewModels
@implements IDisposable

<div class="channel-sidebar-header">Friends</div>

<div class="channel-search">
    <input class="channel-search-input"
           placeholder="Filter friends..."
           @bind="ViewModel.SearchTerm"
           @bind:event="oninput" />
</div>

<div class="segmented-control">
    <button class="segment @(ViewModel.StatusFilter == FriendFilter.All ? "active" : "")"
            @onclick="() => ViewModel.SetActiveFilter(FriendFilter.All)">All</button>
    <button class="segment @(ViewModel.StatusFilter == FriendFilter.Online ? "active" : "")"
            @onclick="() => ViewModel.SetActiveFilter(FriendFilter.Online)">Online</button>
</div>

<div class="channel-list">
    @foreach (var friend in ViewModel.FilteredFriends)
    {
        bool hasUnread = ViewModel.UnreadFriends.Contains(friend.FriendId);
        
        <div class="friend-item @(ViewModel.ActiveFriendId == friend.FriendId ? "active" : "")" 
             @onclick="@(() => ViewModel.OpenChatWithFriend(friend.FriendId))">
             
            <div class="avatar">
                <span>@friend.Username.ToUpper()[0]</span>
                <div class="status @FriendsSidebarViewModel.GetStatusClass(friend.Status)"></div>
            </div>
            
            <span class="friend-name flex-grow-1" style="@(hasUnread ? "font-weight: 800; color: black;" : "")">
                @friend.Username
            </span>

            @if (hasUnread)
            {
                <div style="width: 8px; height: 8px; background-color: #f04747; border-radius: 50%; margin-left: auto;"></div>
            }
        </div>
    }
</div>

@code
{
    [Parameter] public EventCallback<int> OnDmOpened { get; set; }

    protected override async Task OnInitializedAsync()
    {
        ViewModel.OnStateChanged += StateHasChanged;
        await ViewModel.InitializeAsync();
    }

    public void Dispose()
    {
        ViewModel.OnStateChanged -= StateHasChanged;
    }
}