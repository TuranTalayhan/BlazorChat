@page "/register"
@layout Layout.AuthLayout
@inject HttpClient Http
@inject NavigationManager NavManager
@inject ChatAuthStateProvider AuthProvider

<EditForm Model="@_model" OnValidSubmit="RegisterUser">
    <DataAnnotationsValidator />

    <MudText Typo="Typo.h1" Align="Align.Center" Class="font-weight-bold mb-6" Style="color: #333333;font-size: 2.5rem;">
        Create an Account
    </MudText>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4">@_errorMessage</MudAlert>
    }

    <MudTextField @bind-Value="_model.Username"
                  For="@(() => _model.Username)"
                  Placeholder="Username"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Class="mb-4" />

    <MudTextField @bind-Value="_model.Email"
                  For="@(() => _model.Email)"
                  Placeholder="Email"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Class="mb-4" />

    <MudTextField @bind-Value="_model.Password"
                  For="@(() => _model.Password)"
                  Placeholder="Password"
                  InputType="InputType.Password"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Class="mb-4" />

    <MudTextField @bind-Value="_model.ConfirmPassword"
                  For="@(() => _model.ConfirmPassword)"
                  Placeholder="Confirm Password"
                  InputType="InputType.Password"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Class="mb-6" />

    <MudButton ButtonType="ButtonType.Submit"
               Variant="Variant.Filled"
               Color="Color.Info"
               FullWidth="true"
               Class="btn-pill py-2 mb-4"
               DisableElevation="true">
        Register
    </MudButton>

    <div class="d-flex align-center justify-center mt-2">
        <MudText Typo="Typo.body2" Style="color: #9e9e9e;" Class="mr-1">Already have an account?</MudText>
        <MudLink Href="/" Typo="Typo.body2" Underline="Underline.Always">Login</MudLink>
    </div>
</EditForm>

@code {
    private CreateUserDto _model = new();
    private string? _errorMessage;

    private async Task RegisterUser()
    {
        _errorMessage = null;
        var response = await Http.PostAsJsonAsync("api/auth/register", _model);

        if (response.IsSuccessStatusCode)
        {
            var me = await response.Content.ReadFromJsonAsync<MeDto>();
            AuthProvider.NotifyUserAuthenticated(me!);
            NavManager.NavigateTo("/chat");
        }
        else
        {
            var err = await response.Content.ReadFromJsonAsync<ErrorResponse>();
            _errorMessage = err?.Message ?? "Registration failed. Please try again.";
        }
    }

    private record ErrorResponse(string Message);
}
