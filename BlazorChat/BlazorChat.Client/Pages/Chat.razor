@page "/chat"
@rendermode InteractiveAuto

<div class="chat-container">
    <div class="messages-list">
        @foreach (var message in Messages)
        {
            <div class="message-bubble">
                @message
            </div>
        }
    </div>

    <div class="chat-input-wrapper">
        <input type="text" 
               class="chat-input" 
               placeholder="Write message here" 
               @bind="CurrentMessage" 
               @bind:event="oninput" 
               @onkeydown="HandleKeyPress" />
               
        <button class="send-button" @onclick="SendMessage" aria-label="Send">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="22" y1="2" x2="11" y2="13"></line>
                <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
            </svg>
        </button>
    </div>
</div>

@code {
    // Some starting mock data based on your image
    private List<string> Messages = new()
    {
        "Sample message text.",
        "Sample message text."
    };

    private string CurrentMessage { get; set; } = string.Empty;

    private void SendMessage()
    {
        if (string.IsNullOrWhiteSpace(CurrentMessage)) return;
        Messages.Add(CurrentMessage);
        CurrentMessage = string.Empty; // Clear the input box
    }

    private void HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            SendMessage();
        }
    }
}