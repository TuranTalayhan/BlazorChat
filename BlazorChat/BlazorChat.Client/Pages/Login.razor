@page "/"
@layout Layout.AuthLayout
@inject HttpClient Http
@inject NavigationManager NavManager
@inject ChatAuthStateProvider AuthProvider

<EditForm Model="@_model" OnValidSubmit="LoginUser">
    <DataAnnotationsValidator />

    <MudText Align="Align.Center" Class="font-weight-bold mb-6" Style="color: #333333;font-size: 2.5rem;">
        Welcome Back!
    </MudText>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4">@_errorMessage</MudAlert>
    }

    <MudTextField @bind-Value="_model.Email"
                  For="@(() => _model.Email)"
                  Placeholder="Email or Username"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Class="mb-4" />

    <MudTextField @bind-Value="_model.Password"
                  For="@(() => _model.Password)"
                  Placeholder="Password"
                  InputType="InputType.Password"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Class="mb-6" />

    <MudButton ButtonType="ButtonType.Submit"
               Variant="Variant.Filled"
               Color="Color.Info"
               FullWidth="true"
               Class="btn-pill py-2 mb-4"
               DisableElevation="true">
        Log In
    </MudButton>

    <div class="d-flex justify-center mb-4">
        <MudLink Href="#" Typo="Typo.body2" Style="color: #9e9e9e;">Forgot your password?</MudLink>
    </div>

    <div class="d-flex align-center justify-center mt-2">
        <MudText Typo="Typo.body2" Style="color: #9e9e9e;" Class="mr-2">Need an account?</MudText>
        <MudButton Href="/register" Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small" Style="text-transform: none; border-radius: 6px; padding: 2px 10px;">
            Sign Up
        </MudButton>
    </div>
</EditForm>

@code {
    private LoginDto _model = new();
    private string _errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        // Already logged in? Skip login page.
        var state = await AuthProvider.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated == true)
            NavManager.NavigateTo("/chat");
    }

    private async Task LoginUser()
    {
        _errorMessage = "";
        var response = await Http.PostAsJsonAsync("api/auth/login", _model);

        if (response.IsSuccessStatusCode)
        {
            var me = await response.Content.ReadFromJsonAsync<MeDto>();
            AuthProvider.NotifyUserAuthenticated(me!);
            NavManager.NavigateTo("/chat");
        }
        else
        {
            _errorMessage = "Invalid credentials.";
        }
    }
}
