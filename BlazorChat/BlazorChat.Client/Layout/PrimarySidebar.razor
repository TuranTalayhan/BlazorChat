@inject IServerApiService ServerRepo
@inject NavigationState NavState
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@using BlazorChat.Client.Features.Servers
@using BlazorChat.Client.Features.Servers.Dialogs.AddServer
@implements IDisposable

<nav class="primary-nav">
    <div class="server-icons-list">
        <MudTooltip Text="Friends" Placement="Placement.Right">
            <div class="server-icon @(NavState.SelectedServer == null ? "active" : "")"
                 @onclick="() => NavState.SelectServer(null)">
                <MudIcon Icon="@Icons.Material.Filled.People" />
            </div>
        </MudTooltip>

        <div class="server-divider"></div>

        @foreach (var server in _servers)
        {
            <MudTooltip Text="@server.Name" Placement="Placement.Right">
                <div class="server-icon @(NavState.SelectedServer?.Id == server.Id ? "active" : "")"
                     @onclick="() => NavState.SelectServer(server)">
                    @server.Name[0].ToString().ToUpper()
                </div>
            </MudTooltip>
        }
        <div class="server-icons-bottom">
            <MudTooltip Text="Create a Server" Placement="Placement.Right">
                <div class="server-icon add-icon" @onclick="OpenCreateServerModal">
                    <MudIcon Icon="@Icons.Material.Filled.Add" />
                </div>
            </MudTooltip>
        </div>
    </div>
</nav>

@code {
    private List<ServerDto> _servers = [];

    protected override async Task OnInitializedAsync()
    {
        NavState.OnChanged += StateHasChanged;
        
        ServerRepo.OnChanged += OnServersChanged;
        _servers = await ServerRepo.GetAllAsync();
    }

    private async void OnServersChanged()
    {
        _servers = await ServerRepo.GetAllAsync();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavState.OnChanged -= StateHasChanged;
        ServerRepo.OnChanged -= OnServersChanged;
    }
    
    private async Task OpenCreateServerModal()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<CreateServerModal>("Create Server", options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            Snackbar.Add("Server created!", Severity.Success);
        }
    }
}
