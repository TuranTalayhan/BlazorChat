@inject HttpClient Http
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager NavManager

<div class="top-chat-bar">
    <div class="top-bar-actions">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Small"
                   Class="ml-3 btn-pill px-4"
                   StartIcon="@Icons.Material.Filled.AddBox"
                   OnClick="OpenAddServerModal">
            Add Server
        </MudButton>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Success"
                   Size="Size.Small"
                   Class="ml-2 btn-pill px-4"
                   StartIcon="@Icons.Material.Filled.PersonAdd"
                   OnClick="OpenAddFriendModal">
            Add Friend
        </MudButton>

        <MudTooltip Text="Explore Servers">
            <MudIconButton Icon="@Icons.Material.Filled.Explore" Color="Color.Default" />
        </MudTooltip>

        <div class="inbox-container" style="position: relative; display: inline-block;">
            <MudBadge Content="@_pendingRequests.Count"
                      Overlap="true"
                      Color="Color.Error"
                      Visible="@(_pendingRequests.Count > 0)"
                      OffsetX="8"
                      OffsetY="8">
                <MudIconButton Icon="@Icons.Material.Filled.Inbox"
                               Color="Color.Default"
                               OnClick="@ToggleInbox" />
            </MudBadge>

            <MudPopover Open="@_isInboxOpen"
                        Fixed="true"
                        AnchorOrigin="Origin.BottomRight"
                        TransformOrigin="Origin.TopRight"
                        Class="pa-4 inbox-popover-panel"
                        Style="width: 300px; max-height: 400px; overflow-y: auto;">
                <div class="d-flex align-center justify-space-between mb-2">
                    <MudText Typo="Typo.subtitle2">Pending Requests</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="@(() => _isInboxOpen = false)" />
                </div>
                <MudDivider Class="mb-2" />
                @if (!_pendingRequests.Any())
                {
                    <MudText Typo="Typo.body2" Align="Align.Center" Class="py-4">No new requests</MudText>
                }
                else
                {
                    @foreach (var request in _pendingRequests)
                    {
                        <div class="d-flex align-center gap-3 py-2 border-bottom">
                            <MudAvatar Size="Size.Small">@request.RequesterUsername[0]</MudAvatar>
                            <div class="flex-grow-1">
                                <MudText Typo="Typo.body2" Style="font-weight: 600">@request.RequesterUsername</MudText>
                            </div>
                            <div class="d-flex">
                                <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small"
                                               OnClick="@(() => HandleRequest(request, true))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small"
                                               OnClick="@(() => HandleRequest(request, false))" />
                            </div>
                        </div>
                    }
                }
            </MudPopover>
        </div>

        <div class="global-search mx-2">
            <MudIcon Icon="@Icons.Material.Filled.Search" Class="search-icon" />
            <input type="text" class="search-input" placeholder="Search..." />
        </div>
    </div>
</div>

@code {
    private List<PendingFriendshipDto> _pendingRequests = new();
    private bool _isInboxOpen;
    private HubConnection? _hubConnection;

    protected override async Task OnInitializedAsync()
    {
        await LoadPendingRequests();
        
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(NavManager.ToAbsoluteUri("/hubs/chat"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection?.On<PendingFriendshipDto>("SendFriendRequest", async (dto) =>
        {
            await InvokeAsync(() =>
            {
                // Prevent duplicate entries if they spam the button
                if (_pendingRequests.Any(r => r.RequesterId == dto.RequesterId)) return;
                _pendingRequests.Insert(0, dto); // Add to top of list
                Snackbar.Add($"New friend request from {dto.RequesterUsername}!", Severity.Info);
                StateHasChanged();
            });
        });
        if (_hubConnection != null) await _hubConnection.StartAsync();
    }

    private void ToggleInbox() => _isInboxOpen = !_isInboxOpen;

    private async Task LoadPendingRequests()
    {
        try
        {
            var result = await Http.GetFromJsonAsync<List<PendingFriendshipDto>>("api/friendships/pending");
            _pendingRequests = result ?? new();
        }
        catch (HttpRequestException)
        {
            // Not authenticated yet — ignore
        }
    }

    private async Task HandleRequest(PendingFriendshipDto request, bool accept)
    {
        var response = await Http.PatchAsJsonAsync($"api/friendships/{request.RequesterId}", accept);
    
        if (response.IsSuccessStatusCode)
        {
            _pendingRequests.Remove(request);
        
            if (accept)
                Snackbar.Add($"You are now friends with {request.RequesterUsername}!", Severity.Success);
            else
                Snackbar.Add("Request declined.", Severity.Info);
            
            if (!_pendingRequests.Any()) _isInboxOpen = false;
        }
        else
        {
            Snackbar.Add("Something went wrong. Please try again.", Severity.Error);
        }
    }

    private readonly DialogOptions _defaultOptions = new()
    {
        CloseOnEscapeKey = true,
        MaxWidth = MaxWidth.ExtraSmall,
        FullWidth = true,
        CloseButton = true
    };

    private async Task OpenAddFriendModal()
    {
        var dialog = await DialogService.ShowAsync<AddFriendModal>("Add Friend", _defaultOptions);
        await dialog.Result;
    }

    private async Task OpenAddServerModal()
    {
        var dialog = await DialogService.ShowAsync<AddServerModal>("Create Server", _defaultOptions);
        await dialog.Result;
    }
    
    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
