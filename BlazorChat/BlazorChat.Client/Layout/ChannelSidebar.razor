@implements IDisposable
@inject HttpClient Http
@inject IChannelRepository ChannelRepo
@inject NavigationManager NavManager

<div class="channel-sidebar">
    @if (SelectedServer == null)
    {
        <div class="channel-sidebar-header">Friends</div>

        <div class="channel-search">
            <input class="channel-search-input"
                   placeholder="Filter friends..."
                   @bind="_searchTerm"
                   @bind:event="oninput" />
        </div>

        <div class="segmented-control">
            <button class="segment @(IsActiveFilter(""))"
                    @onclick="@(() => _statusFilter = string.Empty)">All</button>
            <button class="segment @(IsActiveFilter("online"))"
                    @onclick="@(() => _statusFilter = "online")">Online</button>
        </div>

        <div class="channel-list">
            @foreach (var friend in FilteredFriends)
            {
                <div class="friend-item">
                    <div class="avatar">
                        <span>@friend.Username.ToUpper()[0]</span>
                        <div class="status @GetStatusClass(friend.Status)"></div>
                    </div>
                    <span class="friend-name">@friend.Username</span>
                </div>
            }
        </div>
    }
    else
    {
        <div class="channel-sidebar-header">@SelectedServer.Name</div>

        <div class="channel-list">
            @if (_loadingChannels)
            {
                <div class="channel-empty">Loading...</div>
            }
            else if (_channels.Count == 0)
            {
                <div class="channel-empty">No channels yet</div>
            }
            else
            {
                @foreach (var group in GroupedChannels)
                {
                    <div class="category-item" @onclick="() => ToggleCategory(group.Key)">
                        <span class="category-name">@(group.Key)</span>
                        @if (ShouldExpand(group))
                        {
                            <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Title="Arrow Down" />   
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowRight" Title="Arrow Right" />
                        }
                    </div>
                    @if (!_collapsedCategories.Contains(group.Key))
                    {
                        @foreach (var ch in group)
                        {
                            <div class="channel-item @(IsActiveChannel(ch.Id))"
                                 @onclick="() => NavToChannel(ch.Id)">
                                <span class="channel-hash">#</span>
                                <span>@ch.Name</span>
                            </div>
                        }       
                    }
                }
            }
        </div>
    }

    <UserProfileFooter />
</div>

@code {
    [Parameter] public ServerDto? SelectedServer { get; set; }

    private List<ChannelDto> _channels = new();
    private List<FriendshipDto> _friends = new();
    private bool _loadingChannels;
    private int? _loadedServerId;
    private int _activeChannelId;
    private string _searchTerm = string.Empty;
    private string _statusFilter = string.Empty;
    private HashSet<string> _collapsedCategories = new();

    protected override async Task OnInitializedAsync()
    {
        NavManager.LocationChanged += OnLocationChanged;
        UpdateActiveChannel();

        try
        {
            var friends = await Http.GetFromJsonAsync<List<FriendshipDto>>("api/friendships");
            _friends = friends ?? new();
        }
        catch (HttpRequestException) { }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (SelectedServer?.Id == _loadedServerId) return;
        _loadedServerId = SelectedServer?.Id;
        _channels =
        [
            new ChannelDto
            {
                Id = 1, Name = "welcome", SortOrder = 1,
                Category = new CategoryDto { Id = 101, Name = "INFORMATION" }
            },

            new ChannelDto
            {
                Id = 2, Name = "rules", SortOrder = 2,
                Category = new CategoryDto { Id = 101, Name = "INFORMATION" }
            },

            // Category: General

            new ChannelDto
            {
                Id = 3, Name = "general", SortOrder = 1,
                Category = new CategoryDto { Id = 102, Name = "TEXT CHANNELS" }
            },

            new ChannelDto
            {
                Id = 4, Name = "off-topic", SortOrder = 2,
                Category = new CategoryDto { Id = 102, Name = "TEXT CHANNELS" }
            },

            // Category: Voice

            new ChannelDto
            {
                Id = 5, Name = "Lounge", SortOrder = 1,
                Category = new CategoryDto { Id = 103, Name = "VOICE CHANNELS" }
            },

            new ChannelDto
            {
                Id = 6, Name = "Gaming", SortOrder = 2,
                Category = new CategoryDto { Id = 103, Name = "VOICE CHANNELS" }
            }
        ];
        _loadingChannels = false;
        /*
        if (SelectedServer != null)
        {
            _loadingChannels = true;
            try
            {
                _channels = await ChannelRepo.GetByServerAsync(SelectedServer.Id);
            }
            finally { _loadingChannels = false; }
        }
        */
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        UpdateActiveChannel();
        InvokeAsync(StateHasChanged);
    }
    
    private void ToggleCategory(string categoryName)
    {
        if (!_collapsedCategories.Add(categoryName))
        {
            _collapsedCategories.Remove(categoryName);
        }
    }

    private void UpdateActiveChannel()
    {
        var match = System.Text.RegularExpressions.Regex.Match(NavManager.Uri, @"/chat/(\d+)");
        _activeChannelId = match.Success ? int.Parse(match.Groups[1].Value) : 0;
    }

    private IEnumerable<FriendshipDto> FilteredFriends => _friends.Where(f =>
        (string.IsNullOrWhiteSpace(_searchTerm) || f.Username.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrWhiteSpace(_statusFilter) || f.Status != UserStatus.Offline)
    );

    private IEnumerable<IGrouping<string?, ChannelDto>> GroupedChannels => 
        _channels.OrderBy(c => c.SortOrder).GroupBy(c => c.Category.Name);
    
    private void NavToChannel(int channelId) => NavManager.NavigateTo("/chat/" + channelId);

    private string IsActiveChannel(int channelId) => _activeChannelId == channelId ? "active" : "";

    private string IsActiveFilter(string filter) => _statusFilter == filter ? "active" : "";

    private string GetStatusClass(UserStatus status) => status switch
    {
        UserStatus.Online => "online",
        UserStatus.Idle => "idle",
        UserStatus.DoNotDisturb => "dnd",
        _ => "offline"
    };

    public void Dispose() => NavManager.LocationChanged -= OnLocationChanged;

    private bool ShouldExpand(IGrouping<string?, ChannelDto> group)
    {
        return !_collapsedCategories.Contains(group.Key);
    }

}
